# Copy this file to .env.local and fill in the values.

# --- Site ---
# Primary public URL, used for metadataBase, Open Graph and canonical links.
# Defaults to https://comms.carephrase.com (production). Override only for
# preview/staging deployments, e.g. a *.vercel.app URL.
NEXT_PUBLIC_SITE_URL=

# --- Supabase ---
# Project URL and anon key from your Supabase project settings (Project Settings > API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- OpenAI ---
# Leave blank to run in MOCK mode (the app works end-to-end with simulated
# transcription and feedback). Add a real key to enable Whisper + GPT-4o.
OPENAI_API_KEY=

# Optional model overrides
OPENAI_FEEDBACK_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Resend (Pilot Access form admin notification) ---
# Leave blank to skip the notification email (leads are still saved in
# Supabase). Get a key at resend.com.
RESEND_API_KEY=
# Admin recipient for new pilot enquiries.
PILOT_NOTIFY_TO=dju78@omoyelejd.co.uk
# Sender. Until your domain is verified in Resend, the code falls back to
# Resend's test sender (onboarding@resend.dev). After DNS verification, set:
# PILOT_NOTIFY_FROM="CarePhrase <noreply@carephrase.com>"
PILOT_NOTIFY_FROM=
